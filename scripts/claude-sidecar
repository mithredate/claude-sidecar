#!/usr/bin/env bash
# claude-sidecar — host-side wrapper that orchestrates the claude-sidecar
# container setup for the current project. Reads ~/.claude-sidecar/config.yaml,
# reads .sidecar/shadow files in the current project and any extra-mount repos,
# builds an OverlaySpec, and invokes `bridge gen-overlay` inside the
# claude-sidecar image to produce compose.sidecar.yml.
#
# Subcommands:
#   claude-sidecar              drift-check, then `docker compose exec ... claude`
#   claude-sidecar up           regenerate overlay and `docker compose up -d`
#   claude-sidecar refresh      explicit regenerate + recreate
#   claude-sidecar exec <cmd>   drift-check, then run arbitrary command in claude container
#   claude-sidecar gen-overlay  print generated overlay to stdout
set -eu

CFG_DIR="${CLAUDE_SIDECAR_CFG_DIR:-$HOME/.claude-sidecar}"
CFG_FILE="$CFG_DIR/config.yaml"
STATE_DIR="$CFG_DIR/state"

die() { printf 'claude-sidecar: %s\n' "$*" >&2; exit 1; }

# Parse a small known YAML schema. Bash-only to avoid a yq dependency. Only
# extracts top-level `image:`, `host_network:`, and the items of
# `extra_mounts:` (a list of paths). Values can be unquoted, double-, or
# single-quoted. Lines starting with '#' are treated as comments.
parse_config() {
    [ -f "$CFG_FILE" ] || die "config not found at $CFG_FILE — create it (image: ..., host_network: ..., extra_mounts: [...])"

    IMAGE=""
    HOST_NETWORK="false"
    EXTRA_MOUNTS=()
    local in_list=0 line key val

    while IFS= read -r line || [ -n "$line" ]; do
        # strip comment, then surrounding whitespace
        line="${line%%#*}"
        case "$line" in (*[!\ \	]*) ;; (*) continue ;; esac

        if [ "$in_list" -eq 1 ] && [[ "$line" =~ ^[[:space:]]+-[[:space:]]+(.*)$ ]]; then
            val="${BASH_REMATCH[1]}"
            val="${val%\"}"; val="${val#\"}"
            val="${val%\'}"; val="${val#\'}"
            val="${val/#\~/$HOME}"
            EXTRA_MOUNTS+=("$val")
            continue
        fi
        # not a list item — closing the list if we were in one
        in_list=0

        if [[ "$line" =~ ^([A-Za-z_]+):[[:space:]]*(.*)$ ]]; then
            key="${BASH_REMATCH[1]}"
            val="${BASH_REMATCH[2]}"
            val="${val%\"}"; val="${val#\"}"
            val="${val%\'}"; val="${val#\'}"
            case "$key" in
                image)        IMAGE="$val" ;;
                host_network) HOST_NETWORK="$val" ;;
                extra_mounts) in_list=1 ;;
            esac
        fi
    done < "$CFG_FILE"

    [ -n "$IMAGE" ] || die "config $CFG_FILE: missing 'image:' field"
}

# Read a shadow file → newline-separated paths (skip blanks + comments).
read_shadow_file() {
    local file="$1"
    [ -f "$file" ] || return 0
    while IFS= read -r line || [ -n "$line" ]; do
        line="${line%%#*}"
        case "$line" in (*[!\ \	]*) ;; (*) continue ;; esac
        # trim surrounding whitespace
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        printf '%s\n' "$line"
    done < "$file"
}

# Print the OverlaySpec YAML to stdout. Reads current project and extra mounts.
emit_spec() {
    local proj_root proj_name
    proj_root="$PWD"
    proj_name="$(basename "$proj_root")"

    printf 'image: %s\n' "$IMAGE"
    printf 'host_network: %s\n' "$HOST_NETWORK"
    printf 'project:\n'
    printf '  host_path: %s\n' "$proj_root"
    printf '  name: %s\n' "$proj_name"
    printf '  shadow_paths:\n'
    while IFS= read -r p; do
        [ -n "$p" ] && printf '    - %s\n' "$p"
    done < <(read_shadow_file "$proj_root/.sidecar/shadow")

    if [ "${#EXTRA_MOUNTS[@]}" -gt 0 ]; then
        printf 'extra_mounts:\n'
        local m name
        for m in "${EXTRA_MOUNTS[@]}"; do
            name="$(basename "$m")"
            printf '  - host_path: %s\n' "$m"
            printf '    name: %s\n' "$name"
            printf '    shadow_paths:\n'
            while IFS= read -r p; do
                [ -n "$p" ] && printf '      - %s\n' "$p"
            done < <(read_shadow_file "$m/.sidecar/shadow")
        done
    fi
}

# Pipe the spec to `bridge gen-overlay` inside the image.
run_gen_overlay() {
    emit_spec | docker run --rm -i "$IMAGE" bridge gen-overlay
}

# Hash all relevant shadow-file contents and the config's extra_mounts list.
# Used by `up` (to record current state) and (later) by `exec` (to detect drift).
compute_shadow_hash() {
    local m
    {
        cat "$PWD/.sidecar/shadow" 2>/dev/null || true
        for m in "${EXTRA_MOUNTS[@]:-}"; do
            printf '%s\n' "EXTRA:$m"
            cat "$m/.sidecar/shadow" 2>/dev/null || true
        done
    } | shasum -a 256 | awk '{print $1}'
}

# Compose -f arg list for the current project: the user's compose.yml, the
# generated compose.sidecar.yml, plus the optional compose.sidecar-local.yml.
compose_args() {
    local -a args=()
    [ -f "$PWD/compose.yml" ]   && args+=(-f compose.yml)
    [ -f "$PWD/compose.yaml" ]  && args+=(-f compose.yaml)
    args+=(-f compose.sidecar.yml)
    [ -f "$PWD/compose.sidecar-local.yml" ] && args+=(-f compose.sidecar-local.yml)
    printf '%s\n' "${args[@]}"
}

# ---- subcommands -----------------------------------------------------------

cmd_gen_overlay() {
    parse_config
    run_gen_overlay
}

cmd_up() {
    parse_config
    run_gen_overlay > "$PWD/compose.sidecar.yml"
    mkdir -p "$STATE_DIR"
    compute_shadow_hash > "$STATE_DIR/$(basename "$PWD").sha"
    local cargs=()
    while IFS= read -r a; do cargs+=("$a"); done < <(compose_args)
    docker compose "${cargs[@]}" up -d "$@"
}

# ---- dispatch --------------------------------------------------------------

main() {
    local sub="${1:-}"
    case "$sub" in
        gen-overlay) shift; cmd_gen_overlay "$@" ;;
        up)          shift; cmd_up "$@" ;;
        "")          die "no subcommand yet implemented (try: gen-overlay, up)" ;;
        *)           die "unknown subcommand: $sub" ;;
    esac
}

main "$@"
