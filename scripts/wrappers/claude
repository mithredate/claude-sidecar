#!/bin/sh
# claude wrapper
# ==============
# The container starts as root (for firewall init), so `docker compose exec claude
# claude` would otherwise run Claude as root and miss the seeded auth in
# /home/claude/.claude. This wrapper drops to the non-root 'claude' user and injects
# the CLAUDE_YOLO flag. Placed ahead of /usr/local/bin on PATH.
REAL_CLAUDE=/usr/local/bin/claude

# Add --dangerously-skip-permissions when CLAUDE_YOLO=1
if [ "$CLAUDE_YOLO" = "1" ]; then
    set -- --dangerously-skip-permissions "$@"
fi

if [ "$(id -u)" -eq 0 ]; then
    # runuser sets HOME/USER from the target's passwd entry and passes args
    # through without a shell re-split (avoids quoting/injection issues).
    exec runuser -u claude -- "$REAL_CLAUDE" "$@"
else
    exec "$REAL_CLAUDE" "$@"
fi
